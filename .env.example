# P004 환경변수 — 이 파일을 .env로 복사 후 실제 값 입력

# === Claude API (포스트 작성) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Brave Search API (리서치) ===
BRAVE_API_KEY=BSA...

# === Google Blogger API ===
BLOGGER_BLOG_ID=123456789          # 블로그 ID (URL에서 확인)
BLOGGER_ACCESS_TOKEN=              # OAuth2 access token (run_oauth.py로 발급)
BLOGGER_REFRESH_TOKEN=             # OAuth2 refresh token

# === Google OAuth2 (token 갱신용) ===
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# === Google Search Console ===
GSC_SITE_URL=https://yourblog.blogspot.com/   # 블로그 URL (/ 포함)

# === SNS 배포 ===
IMGBB_API_KEY=           # 이미지 공개 URL (ImgBB 무료, https://api.imgbb.com/)

# === Instagram ===
INSTAGRAM_ACCESS_TOKEN=  # Instagram Graph API 장기 토큰
INSTAGRAM_ACCOUNT_ID=    # Instagram 비즈니스 계정 ID

# === X (Twitter) ===
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# === YouTube ===
YOUTUBE_CHANNEL_ID=      # YouTube 채널 ID

# === 쇼츠 영상 ===
GOOGLE_TTS_API_KEY=      # Google Cloud TTS (없으면 gTTS 무료 사용)
OPENAI_API_KEY=          # DALL-E 3 배경 이미지 (없으면 단색 배경)
FFMPEG_PATH=             # ffmpeg 경로 (PATH 미등록 시만, 예: /usr/bin/ffmpeg)

# === 블로그 URL ===
BLOG_URL=https://ai-insight-blog.blogspot.com
